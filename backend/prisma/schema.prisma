// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(uuid())
  username             String    @unique
  password             String?
  role                 Role
  isActive             Boolean   @default(true)
  passwordSetupToken   String?
  passwordSetupExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reportsCreated  Report[] @relation("ReportsCreated")
  reportsAsClient Report[] @relation("ReportsForClient")

  @@index([username])
}

model Report {
  id   String     @id @default(uuid())
  type ReportType

  clientId    String
  createdById String

  reportDate DateTime
  content    Json

  client    User @relation("ReportsForClient", fields: [clientId], references: [id])
  createdBy User @relation("ReportsCreated", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@unique([clientId, reportDate, type])
}

enum ReportType {
  AUDIT
  DM
}

enum Role {
  AUDITOR
  DM
  ADMIN
  CLIENT
}
