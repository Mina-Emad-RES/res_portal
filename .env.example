# ─────────────────────────────
# App URLs
# ─────────────────────────────
# Frontend public URL (used by Vite)
VITE_FRONTEND_URL=http://localhost

# Backend API base URL
VITE_API_URL=http://localhost/api


# ─────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────
POSTGRES_DB=res_portal
POSTGRES_USER=res_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Prisma / backend connection string
DATABASE_URL=postgresql://res_user:CHANGE_ME@postgres:5432/res_portal?schema=public


# ─────────────────────────────
# Backend auth / admin
# ─────────────────────────────
# Initial admin password (change in production)
ADMIN_PASSWORD=CHANGE_ME

# JWT signing secret
JWT_SECRET=CHANGE_ME_SUPER_SECRET
